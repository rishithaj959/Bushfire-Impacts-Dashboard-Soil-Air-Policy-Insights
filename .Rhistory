install.packages("stringr")
library(readxl)
library(dplyr)
library(janitor)
library(stringr)
# 📥 2. Load Excel data with correct sheet and convert "NR" to NA
df <- read_excel("impact-of-temperatures-on-soil-leachability.xlsx",
sheet = "Leachate concentations ",
na = "NR")
# 🧼 3. Clean column names
df <- janitor::clean_names(df)
# ✅ 4. Extract numeric temperature from text like "Unburnt (23)"
temp_col <- grep("temperature.*leach", colnames(df), value = TRUE)
if (length(temp_col) > 0) {
df$temperature <- gsub("[^0-9]", "", df[[temp_col]])
df$temperature <- as.numeric(df$temperature)
} else {
stop("❌ Temperature column not found.")
}
# 🔄 5. Coerce character columns to numeric where possible (after NR handling)
df <- df %>%
mutate(across(where(is.character), ~ suppressWarnings(as.numeric(.)), .names = "converted_{col}"))
# Replace original numeric columns with converted values (if any)
converted_cols <- grep("^converted_", colnames(df), value = TRUE)
if (length(converted_cols) > 0) {
for (col in converted_cols) {
original_col <- gsub("converted_", "", col)
df[[original_col]] <- df[[col]]
}
df <- df[, !colnames(df) %in% converted_cols]  # drop temp columns
}
# 🧽 6. Drop completely empty rows
df <- df[rowSums(is.na(df)) != ncol(df), ]
# 🔍 7. Drop columns with >20% missing data
threshold <- 0.2 * nrow(df)
df <- df[, colSums(is.na(df)) < threshold]
# 🧠 8. Fill missing values
numeric_cols <- sapply(df, is.numeric)
categorical_cols <- sapply(df, function(x) is.character(x) || is.factor(x))
# Fill numeric with median
df[numeric_cols] <- lapply(df[numeric_cols], function(x) {
x[is.na(x)] <- median(x, na.rm = TRUE)
return(x)
})
# Fill categorical with mode
get_mode <- function(x) {
ux <- unique(x[!is.na(x)])
ux[which.max(tabulate(match(x, ux)))]
}
df[categorical_cols] <- lapply(df[categorical_cols], function(x) {
x[is.na(x)] <- get_mode(x)
return(x)
})
# 🚫 9. Remove outliers using IQR
remove_outliers_iqr <- function(x) {
Q1 <- quantile(x, 0.25, na.rm = TRUE)
Q3 <- quantile(x, 0.75, na.rm = TRUE)
IQR_val <- Q3 - Q1
lower_bound <- Q1 - 1.5 * IQR_val
upper_bound <- Q3 + 1.5 * IQR_val
x[x < lower_bound | x > upper_bound] <- NA
return(x)
}
df[numeric_cols] <- lapply(df[numeric_cols], remove_outliers_iqr)
# Re-impute with median after outlier removal
df[numeric_cols] <- lapply(df[numeric_cols], function(x) {
x[is.na(x)] <- median(x, na.rm = TRUE)
return(x)
})
# ⚠️ 10. Filter valid temperature range
df <- df %>% filter(temperature >= 15, temperature <= 900)
# 💾 11. Save full cleaned dataset
write.csv(df, "cleaned_leachate_concentrations.csv", row.names = FALSE)
# 🎯 12. Select relevant columns for your research questions
# ✅ Define actual available columns for analysis
filtered_df <- df %>%
select(
temperature,                             # Fire intensity
tn_mg_l, tp_mg_l, n_ox_mg_l, po4_3_mg_l, nh4_mg_l,  # Nutrients
zn_mg_l, fe_mg_l, pb_mg_l, cd_mg_l, ni_mg_l, cu_mg_l,
al_mg_l, as_mg_l, cr_mg_l, co_mg_l, mo_mg_l, mn_mg_l,
sb_mg_l, se_mg_l, u_mg_l, v_mg_l,               # Metals
sample_site                                # Site metadata (only available one)
)
write.csv(filtered_df, "leachate_data_for_analysis.csv", row.names = FALSE)
