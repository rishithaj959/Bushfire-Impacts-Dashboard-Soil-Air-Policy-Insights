# Load necessary packages
install.packages("ggmap")
library(ggplot2)
library(gganimate)
library(dplyr)
library(lubridate)
library(sf)         # for shapefiles (if bushfire polygons)
library(ggthemes)   # for map styling
library(ggmap)      # if base map needed
# 1. Load and prepare bushfire and air quality data
# Assuming your cleaned data is in a data.frame called `bushfire_airquality_merged`
# Columns needed: datetime, lat, lon, pm25, city, fire_count or fire_intensity
# Convert datetime if not already
bushfire_airquality_merged <- bushfire_airquality_merged %>%
mutate(date = as.Date(datetime))
install.packages(c("plotly", "dplyr", "readr", "lubridate"))
knitr::opts_chunk$set(echo = TRUE)
library(plotly)
library(dplyr)
library(readr)
library(lubridate)
# Load your air quality dataset
df <- read_csv("wrangled_air_quality_data.csv")
# Filter to valid entries
df <- df %>%
filter(!is.na(bushfire_period), !is.na(bpm2_5), !is.na(location_name), !is.na(datetime_aest))
# Convert to Date format
df <- df %>%
mutate(date = as.Date(datetime_aest))
# Approximate coordinates for each station
station_coords <- tibble::tibble(
location_name = c("Morwell East", "Morwell South", "Geelong South", "Traralgon",
"Alphington", "Footscray", "Churchill", "Melbourne Cbd", "Newborough", "Moe"),
latitude = c(-38.234, -38.257, -38.173, -38.193, -37.776, -37.799, -38.312, -37.8136, -38.179, -38.179),
longitude = c(146.417, 146.393, 144.357, 146.540, 145.031, 144.899, 146.417, 144.9631, 146.280, 146.260)
)
# Merge coordinates into your data
df <- left_join(df, station_coords, by = "location_name")
# Filter again to ensure coords are present
df <- df %>%
filter(!is.na(latitude), !is.na(longitude))
# Animate using plotly
fig <- plot_ly(
data = df,
type = 'scattergeo',
mode = 'markers',
lat = ~latitude,
lon = ~longitude,
size = ~bpm2_5,
color = ~bpm2_5,
frame = ~date,
text = ~paste("Station:", location_name,
"<br>PM2.5:", round(bpm2_5, 2),
"<br>Date:", date),
colors = 'Inferno',
marker = list(sizemode = "area", opacity = 0.7)
)
fig <- fig %>% layout(
title = "Animated PM2.5 Air Quality Map with Bushfire Periods",
geo = list(scope = 'australia', showland = TRUE)
)
fig
library(plotly)
library(dplyr)
library(readr)
library(lubridate)
# Load the data
df <- read_csv("wrangled_air_quality_data.csv")
# Filter valid rows
df <- df %>%
filter(!is.na(bushfire_period), !is.na(bpm2_5), !is.na(location_name), !is.na(datetime_aest)) %>%
mutate(date = as.Date(datetime_aest))
# Assign approximate coordinates
station_coords <- tibble::tibble(
location_name = c("Morwell East", "Morwell South", "Geelong South", "Traralgon",
"Alphington", "Footscray", "Churchill", "Melbourne Cbd", "Newborough", "Moe"),
latitude = c(-38.234, -38.257, -38.173, -38.193, -37.776, -37.799, -38.312, -37.8136, -38.179, -38.179),
longitude = c(146.417, 146.393, 144.357, 146.540, 145.031, 144.899, 146.417, 144.9631, 146.280, 146.260)
)
df <- left_join(df, station_coords, by = "location_name") %>%
filter(!is.na(latitude), !is.na(longitude))
# Convert bushfire_period to factor for coloring
df$bushfire_period <- factor(df$bushfire_period, levels = c("No", "Yes"))
# Animated plot using bushfire_period as color and PM2.5 as size
fig <- plot_ly(
data = df,
type = 'scattergeo',
mode = 'markers',
lat = ~latitude,
lon = ~longitude,
color = ~bushfire_period,        # coloring by bushfire period
frame = ~date,
size = ~bpm2_5,
sizes = c(5, 25),
text = ~paste("Station:", location_name,
"<br>PM2.5:", round(bpm2_5, 2),
"<br>Date:", date,
"<br>Bushfire Period:", bushfire_period),
marker = list(sizemode = "diameter", opacity = 0.7)
)
fig <- fig %>% layout(
title = "PM2.5 Levels and Bushfire Periods (Animated Map)",
geo = list(scope = 'australia', showland = TRUE),
legend = list(title = list(text = "Bushfire Period"))
)
fig
