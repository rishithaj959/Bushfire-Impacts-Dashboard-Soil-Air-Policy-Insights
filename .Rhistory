# 📦 Load required packages
install.packages("tidyverse")
install.packages("janitor")
library(tidyverse)
library(janitor)
library(readxl)
library(reshape2)
# 📥 Load datasets
before <- read_excel("impact-of-temperatures-on-soil-leachability.xlsx",
sheet = "Leachate concentations ",
na = "NR")
after <- read.csv("leachate_data_for_analysis.csv")
# 🧼 Clean column names
before <- clean_names(before)
after <- clean_names(after)
# ✏️ Add dataset labels
before$Dataset <- "Before"
after$Dataset <- "After"
# 🧱 Keep only common columns + dataset label
common_cols <- intersect(colnames(before), colnames(after))
before <- before[, c(common_cols, "Dataset")]
after <- after[, c(common_cols, "Dataset")]
# 🔍 Focus on numeric columns + first 50 rows for readability
before_subset <- before %>% select(where(is.numeric)) %>% slice(1:50)
after_subset <- after %>% select(where(is.numeric)) %>% slice(1:50)
# 🔢 Add observation row index
before_subset$row <- 1:nrow(before_subset)
after_subset$row <- 1:nrow(after_subset)
# 🔄 Reshape into long format
before_long <- melt(before_subset, id.vars = "row")
after_long <- melt(after_subset, id.vars = "row")
before_long$Dataset <- "Before"
after_long$Dataset <- "After"
# 📊 Combine and compute missingness
combined_long <- bind_rows(before_long, after_long) %>%
mutate(Missing = is.na(value))
# ✅ Ensure correct facet order: Before first, After second
combined_long$Dataset <- factor(combined_long$Dataset, levels = c("Before", "After"))
# 🎨 Plot tile map
ggplot(combined_long, aes(x = variable, y = row, fill = Missing)) +
geom_tile(color = "white") +
scale_fill_manual(
values = c("FALSE" = "#cce5df", "TRUE" = "#ff6b6b"),
labels = c("FALSE" = "Available", "TRUE" = "Unavailable")
) +
facet_wrap(~Dataset, ncol = 1) +
labs(
title = "Side-by-Side Tile Map of Missing Values",
x = "Variable", y = "Observation", fill = "Data Status"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# 📦 Load required packages
library(janitor)
library(readxl)
library(reshape2)
# 📥 Load datasets
before <- read_excel("impact-of-temperatures-on-soil-leachability.xlsx",
sheet = "Leachate concentations ",
na = "NR")
after <- read.csv("leachate_data_for_analysis.csv")
# 🧼 Clean column names
before <- clean_names(before)
after <- clean_names(after)
# ✏️ Add dataset labels
before$Dataset <- "Before"
after$Dataset <- "After"
# 🧱 Keep only common columns + dataset label
common_cols <- intersect(colnames(before), colnames(after))
before <- before[, c(common_cols, "Dataset")]
after <- after[, c(common_cols, "Dataset")]
# 🔍 Focus on numeric columns + first 50 rows for readability
before_subset <- before %>% select(where(is.numeric)) %>% slice(1:50)
after_subset <- after %>% select(where(is.numeric)) %>% slice(1:50)
# 🔢 Add observation row index
before_subset$row <- 1:nrow(before_subset)
after_subset$row <- 1:nrow(after_subset)
# 🔄 Reshape into long format
before_long <- melt(before_subset, id.vars = "row")
after_long <- melt(after_subset, id.vars = "row")
before_long$Dataset <- "Before"
after_long$Dataset <- "After"
# 📊 Combine and compute missingness
combined_long <- bind_rows(before_long, after_long) %>%
mutate(Missing = is.na(value))
# ✅ Ensure correct facet order: Before first, After second
combined_long$Dataset <- factor(combined_long$Dataset, levels = c("Before", "After"))
# 🎨 Plot tile map
ggplot(combined_long, aes(x = variable, y = row, fill = Missing)) +
geom_tile(color = "white") +
scale_fill_manual(
values = c("FALSE" = "#cce5df", "TRUE" = "#ff6b6b"),
labels = c("FALSE" = "Available", "TRUE" = "Unavailable")
) +
facet_wrap(~Dataset, ncol = 1) +
labs(
title = "Side-by-Side Tile Map of Missing Values",
x = "Variable", y = "Observation", fill = "Data Status"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
