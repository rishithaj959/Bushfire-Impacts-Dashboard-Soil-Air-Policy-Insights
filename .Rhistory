# 📦 Load required libraries
install.packages("readxl")
install.packages("ggplot2")
install.packages("reshape2")
library(readxl)
library(ggplot2)
library(reshape2)
# 📥 Load both datasets
before <- read_excel("impact-of-temperatures-on-soil-leachability.xlsx",
sheet = "Leachate concentations ",
na = "NR")
after <- read.csv("leachate_data_for_analysis.csv")
# 🧼 Clean column names if needed
before <- janitor::clean_names(before)
after <- janitor::clean_names(after)
# 🔹 1. Missing Value Count Plot (only for common columns)
missing_before <- colSums(is.na(before))
missing_after <- colSums(is.na(after))
common_cols <- intersect(names(missing_before), names(missing_after))
missing_df <- data.frame(
Column = common_cols,
Before = missing_before[common_cols],
After = missing_after[common_cols]
)
missing_long <- melt(missing_df, id.vars = "Column")
ggplot(missing_long, aes(x = reorder(Column, -value), y = value, fill = variable)) +
geom_bar(stat = "identity", position = "dodge") +
coord_flip() +
labs(title = "Missing Values Per Column: Before vs After Cleaning",
x = "Column", y = "Missing Count", fill = "Dataset") +
theme_minimal()
# 🔹 2. Distribution comparison for one key variable (e.g., zn_mg_l)
par(mfrow = c(1, 2))
hist(before$zn_mg_l, main = "Zinc Before Cleaning", col = "skyblue", xlab = "zn_mg_l")
hist(after$zn_mg_l, main = "Zinc After Cleaning", col = "lightgreen", xlab = "zn_mg_l")
# 🔹 3. Boxplots of key variables before and after
selected_cols <- c("zn_mg_l", "tp_mg_l", "po4_3_mg_l", "cd_mg_l")
# Keep only available columns
available <- selected_cols[selected_cols %in% intersect(names(before), names(after))]
# Combine data for plotting
box_df <- rbind(
transform(before[available], dataset = "Before"),
transform(after[available], dataset = "After")
)
box_long <- melt(box_df, id.vars = "dataset")
ggplot(box_long, aes(x = variable, y = value, fill = dataset)) +
geom_boxplot(outlier.shape = NA) +
scale_y_log10() +
labs(title = "Boxplot of Key Variables (Log Scale)", x = "Variable", y = "Log(Value)", fill = "Dataset") +
theme_minimal()
# 🔹 4. Row and Column Counts
compare_dims <- data.frame(
Stage = c("Before", "After"),
Rows = c(nrow(before), nrow(after)),
Columns = c(ncol(before), ncol(after))
)
compare_long <- melt(compare_dims, id.vars = "Stage")
ggplot(compare_long, aes(x = variable, y = value, fill = Stage)) +
geom_bar(stat = "identity", position = "dodge") +
labs(title = "Dataset Dimensions: Before vs After", x = "Metric", y = "Count") +
theme_minimal()
